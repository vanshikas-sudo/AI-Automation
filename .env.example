# ── WhatsApp Cloud API ──────────────────────────────────
WHATSAPP_API_TOKEN="Your WhatsApp API token here (keep it secret!)"
WHATSAPP_PHONE_NUMBER_ID="Your WhatsApp phone number ID here"
WHATSAPP_VERIFY_TOKEN="Your custom verify token here"
WHATSAPP_APP_SECRET="Your WhatsApp app secret here"

# ── LLM Provider ────────────────────────────────────────
# Supported: anthropic | openai | azure | google | groq
LLM_PROVIDER=azure

# API key for the chosen provider
LLM_API_KEY="Your LLM API key here (keep it secret!)"

# Model override (leave empty to use provider default)
# Defaults: anthropic→claude-sonnet-4-20250514, openai→gpt-4o, azure→gpt-4o,
#           google→gemini-2.0-flash, groq→llama-3.3-70b-versatile
LLM_MODEL="LLM model name here (optional, leave empty for default)"

# ── Azure OpenAI (only when LLM_PROVIDER=azure) ────────
AZURE_ENDPOINT="Your Azure OpenAI endpoint here (e.g., https://your-resource-name.openai.azure.com/)"
AZURE_API_VERSION=2024-12-01-preview
AZURE_DEPLOYMENT="Your Azure OpenAI deployment name here"

LLM_SYSTEM_PROMPT=You are a helpful WhatsApp assistant with access to Zoho CRM and Zoho Books tools. Keep replies concise and conversational. IMPORTANT: When calling any ZohoBooks tool, you MUST always include the organization_id parameter.

# ── MCP Server ──────────────────────────────────────────
MCP_ZOHO_URL="Your MCP server URL here (e.g., https://your-mcp-server.com/mcp/your-endpoint/message)"
