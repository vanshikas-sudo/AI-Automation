# ── WhatsApp Cloud API ──────────────────────────────────
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_APP_SECRET=your_app_secret

# ── LLM Provider (Multi-LLM Support) ───────────────────
# Supported: anthropic | openai | azure | google | groq
LLM_PROVIDER=anthropic

# API key for the chosen provider
LLM_API_KEY=your_llm_api_key

# Model override (leave empty to use provider default)
# Defaults: anthropic→claude-sonnet-4-20250514, openai→gpt-4o, azure→gpt-4o,
#           google→gemini-2.0-flash, groq→llama-3.3-70b-versatile
LLM_MODEL=

# System prompt (kept minimal — intent router handles scoping)
LLM_SYSTEM_PROMPT=You are a concise WhatsApp assistant with Zoho integration. Keep replies short. Format responses for mobile readability.

# ── Zoho ────────────────────────────────────────────────
# Auto-detected at startup if empty
ZOHO_ORG_ID=your_zoho_org_id

# ── Azure OpenAI (only when LLM_PROVIDER=azure) ────────
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-12-01-preview
AZURE_DEPLOYMENT=your-deployment-name

# ── MCP Server (Zoho) ──────────────────────────────────
MCP_ZOHO_URL=your_zoho_mcp_url

# ── Token Optimization ─────────────────────────────────
MAX_HISTORY_MESSAGES=10
SESSION_TTL_MINUTES=30
